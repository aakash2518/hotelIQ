# ============================================================
# HotelIQ Environment Variables — COPY TO .env AND FILL IN
# ============================================================
# DO NOT commit your .env file. This file is safe to commit.

# ------------------------------------------------------------
# LLM Provider
# Choose one: gemini | groq | openai | ollama
# ------------------------------------------------------------
LLM_PROVIDER=gemini

# Google Gemini (free) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (free) — https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# OpenAI (optional fallback)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ------------------------------------------------------------
# Database (Supabase PostgreSQL)
# Dashboard → Project Settings → Database → Connection Pooler
# ------------------------------------------------------------

# Pooler URL — used at runtime (IPv4 compatible, port 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL — used for migrations / db push (port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# Optional Services (not required in development)
# ------------------------------------------------------------
KAFKA_BROKER=localhost:9092
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=4000
NODE_ENV=development

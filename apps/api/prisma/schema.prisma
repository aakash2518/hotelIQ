// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}


model Hotel {
  id            String   @id @default(cuid())
  name          String
  city          String
  country       String
  starRating    Int
  createdAt     DateTime @default(now())
  prices        HotelPrice[]
  embeddings    HotelEmbedding[]
}

model HotelPrice {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  source        String   // "booking.com", "expedia", "hotels.com"
  priceUSD      Float
  checkIn       DateTime
  checkOut      DateTime
  recordedAt    DateTime @default(now())

  @@index([hotelId])
  @@index([recordedAt])
}

model HotelEmbedding {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  embedding     Unsupported("vector(1536)")?
  textContent   String   // what was embedded
  createdAt     DateTime @default(now())

  @@index([hotelId])
}

model Campaign {
  id            String   @id @default(cuid())
  name          String
  targetCity    String
  targetSegment String   // "budget", "luxury", "family"
  channel       String   // "email", "push", "sms"
  content       String
  status        String   @default("draft") // draft, active, completed
  metrics       Json?    // { sent, opened, clicked, converted }
  agentDecision Json?    // { reasoning, confidence, factors }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AgentLog {
  id            String   @id @default(cuid())
  agentName     String   // "research", "decisioning", "execution"
  action        String
  input         Json
  output        Json
  latencyMs     Int
  tokenCost     Int?
  confidence    Float?
  createdAt     DateTime @default(now())

  @@index([agentName])
  @@index([createdAt])
}
